{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "merchants.shansi.app"
        }
      ],
      "destination": "/merchant/register"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "merchants.shansi.app"
        }
      ],
      "destination": "/merchant/register",
      "permanent": false
    }
  ]
}
